# anrbj666-thief — environment example (PLACEHOLDERS ONLY, never real values)
# Copy to `.env` (which is git-ignored) and fill locally. Do NOT commit `.env`.

# ---- Role ----
AGENT_ROLE=thief

# ---- Peer networking (public P2P over FastMCP) ----
# Own public base URL once tunneled (ngrok/localtonet). Leave empty for localhost.
SELF_PUBLIC_URL=
SELF_HOST=127.0.0.1
SELF_PORT=8902
# Opponent peer public MCP endpoint (obtained during matchmaking).
PEER_PUBLIC_URL=

# ---- Tunnel (secret token lives ONLY here / in tunnel config, never in code) ----
NGROK_AUTHTOKEN=REPLACE_WITH_YOUR_NGROK_TOKEN

# ---- LLM Gatekeeper (default template mode = no external calls, no key) ----
# One of: template | ollama | claude_api | claude_cli   (see Appendix F, Table 21)
LLM_PROVIDER=template
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY_IF_USING_claude_api

# ---- Gmail reporting (OAuth 2.0, send-only). Files stay git-ignored. ----
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
REPORT_TO=rmisegal+uoh26finalgame@gmail.com
